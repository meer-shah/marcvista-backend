# Copy this file to .env and fill in real values — never commit .env

PORT=4000
NODE_ENV=development

# MongoDB connection string (use MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/marcvista

# JWT — generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption key for stored Bybit API credentials (32-byte hex)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY

# Frontend URL for CORS — comma-separated list
# Production example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:8080,http://localhost:5173

# Email (for password reset) — use an app-specific password, not your main password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM=your@gmail.com

# Sentry error tracking — optional, leave blank to disable
SENTRY_DSN=
